# Root .gitignore for ArthaPath Nepal

# Environment variables - NEVER commit these
.env
.env.*
!.env.example
*.env

# Dependencies
node_modules/
npm-debug.log*
yarn-debug.log*
yarn-error.log*
pnpm-debug.log*

# OS files
.DS_Store
Thumbs.db
*.swp
*.swo
*~

# IDE files
.vscode/
.idea/
*.iml
*.sublime-*

# Build outputs
dist/
build/
out/
.next/

# Logs
logs/
*.log

# Database
*.sqlite
*.db

# Temporary files
tmp/
temp/
*.tmp

# Coverage
coverage/
.nyc_output/

# TypeScript
*.tsbuildinfo

# Package manager lock files (optional - uncomment if you want to ignore)
# package-lock.json
# yarn.lock
# pnpm-lock.yaml
